<script>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var ans = btn.nextElementSibling;
      var icon = btn.querySelector('span');
      var open = !ans.classList.contains('hidden');
      ans.classList.toggle('hidden');
      icon.textContent = open ? '+' : '-';
    });
  });

  function performLegacySearch(query) {
    if (!query) return;
    var searchTerm = query.toLowerCase().replace(/\s{2,}/g, " ").trim();
    if (searchTerm === "") return;

    var words = searchTerm.split(" ");
    if (words.length > 10) {
      words = words.filter(function(word) {
        var w = word.toLowerCase();
        return w !== "with" && w !== "in" && w !== "of" && w !== "and";
      });
      if (words.length > 10) words = words.slice(0, 10);
      if (words.length === 0) return;
    }

    var slug = words.map(function(word) {
      return word.replace(/'/g, "");
    }).join("-");

    if (slug && slug !== "search-png-images") {
      var target = "https://www.cleanpng.com/free/" + slug + ".html";
      var tag = slug + "_user";

      // Keep legacy hit tracking behavior from cleanpng_web_en.
      fetch("https://topdata.freepnges.com/cleanpng_hits_process.php?id=" + encodeURIComponent(tag) + "&hl=cleanpngtag_user")
        .catch(function() {});

      window.location.href = target;
    }
  }

  function bindSearchInputEnter(input) {
    if (!input) return;
    input.addEventListener("keydown", function(e) {
      if (e.key === "Enter") {
        e.preventDefault();
        performLegacySearch(input.value);
      }
    });
  }

  var headerInput = document.getElementById("header-search-input");
  var headerBtn = document.getElementById("header-search-btn");
  var mobileHeaderInput = document.getElementById("mobile-header-search-input");
  var mobileHeaderBtn = document.getElementById("mobile-header-search-btn");
  var heroInput = document.getElementById("hero-search-input");
  var heroBtn = document.getElementById("hero-search-btn");

  bindSearchInputEnter(headerInput);
  bindSearchInputEnter(mobileHeaderInput);
  if (headerBtn && headerInput) {
    headerBtn.addEventListener("click", function(e) {
      e.preventDefault();
      performLegacySearch(headerInput.value);
    });
  }
  if (mobileHeaderBtn && mobileHeaderInput) {
    mobileHeaderBtn.addEventListener("click", function(e) {
      e.preventDefault();
      performLegacySearch(mobileHeaderInput.value);
    });
  }
  bindSearchInputEnter(heroInput);
  if (heroBtn && heroInput) {
    heroBtn.addEventListener("click", function(e) {
      e.preventDefault();
      performLegacySearch(heroInput.value);
    });
  }
</script>
