<style>

    body { font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; }
    .page-shell { width: 100%; max-width: none; margin: 0; }
    @media (min-width: 1024px) { .page-shell { padding-left: 56px !important; padding-right: 56px !important; } }

    .chip { border: 1px solid #d8e2df; border-radius: 9999px; padding: 6px 12px; font-size: 12px; font-weight: 700; color: #344054; background: #fff; }
    .chip:hover { border-color: #178f62; color: #178f62; }

    .card-title { font-size: 14px; font-weight: 800; line-height: 1.25; margin-top: 10px; color: #0f172a; }
    .card-tags { margin-top: 8px; display: flex; flex-wrap: wrap; gap: 6px 8px; }
    .card-tags a { display: inline-flex; align-items: center; border-radius: 9999px; padding: 4px 12px; font-size: 12px; font-weight: 700; line-height: 1; color: #64748b; background: #e8eef3; }
    .card-tags a:hover { color: #178f62; background: #dff5ec; }

    /* Trend collage cards: desktop is exactly 5 cards per row. */
    .collage-grid { display: grid; gap: 1.25rem; grid-template-columns: repeat(5, minmax(0, 1fr)); align-items: start; }
    .collage-card { display: block; min-width: 0; }
    .collage-card > a { box-shadow: 0 0 0 rgba(15, 23, 42, 0); }
    .collage-card > a:hover { transform: translateY(-1px); box-shadow: 0 20px 44px rgba(15, 23, 42, 0.1); }
    .trend-card__title { margin-top: 10px; font-size: 16px; line-height: 1.25; font-weight: 800; color: #0f172a; }
    .trend-card__meta { margin-top: 3px; font-size: 14px; color: #64748b; }
    .collage-media { display: grid; aspect-ratio: 1 / 1; grid-template-columns: repeat(2, minmax(0, 1fr)); grid-template-rows: repeat(2, minmax(0, 1fr)); gap: 4px; background: #fff; padding: 4px; }
    .collage-media img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .collage-media--left-large > :first-child { grid-column: 1; grid-row: 1 / span 2; }
    .collage-media--left-large > :nth-child(2) { grid-column: 2; grid-row: 1; }
    .collage-media--left-large > :nth-child(3) { grid-column: 2; grid-row: 2; }
    .collage-media--right-large > :first-child { grid-column: 1; grid-row: 1; }
    .collage-media--right-large > :nth-child(2) { grid-column: 1; grid-row: 2; }
    .collage-media--right-large > :nth-child(3) { grid-column: 2; grid-row: 1 / span 2; }
    .media-hover { position: relative; overflow: hidden; }
    .media-hover::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(15, 23, 42, 0.02), rgba(15, 23, 42, 0.12)); opacity: 0; transition: opacity 180ms ease; pointer-events: none; }
    .media-hover:hover::after { opacity: 1; }

    /* Fresh PNG list: natural image-width flow, not fixed equal-width cards. */
    .png-flow-grid { display: flex; flex-wrap: wrap; align-items: flex-start; gap: 28px 14px; }
    .png-card { flex: 0 0 auto; width: min-content; max-width: 390px; }
    .png-card__media { display: block; overflow: hidden; border-radius: 4px; background: #fff; }
    .png-card__media img { display: block; width: auto; height: 250px; max-width: 390px; object-fit: contain; }
    .png-card .card-title { max-width: 100%; }

    @media (max-width: 1280px) { .png-card__media img { height: 220px; max-width: 340px; } .png-card { max-width: 340px; } }
    @media (max-width: 1024px) { .collage-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } .png-card__media img { height: 200px; max-width: 300px; } .png-card { max-width: 300px; } }
    @media (max-width: 768px) { .collage-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } .png-flow-grid { gap: 24px 12px; } .png-card__media img { height: 180px; max-width: 260px; } .png-card { max-width: 260px; } }
    @media (max-width: 520px) { .collage-grid { grid-template-columns: repeat(1, minmax(0, 1fr)); } .png-card { width: 100%; max-width: none; } .png-card__media img { width: 100%; height: auto; max-width: none; } }
</style>
</head>
<body class="bg-white text-slate-900">

<!-- ===================== HEADER (EDIT LINKS) ===================== -->
<header class="sticky top-0 z-50 border-b border-slate-100 bg-white/95 backdrop-blur">
  <div class="page-shell flex items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
    <div class="flex items-center gap-8">
      <a href="https://www.cleanpng.com" class="text-2xl font-black tracking-tight">Clean<span class="text-brand-green">PNG</span></a>
      <nav class="hidden gap-6 text-sm font-semibold text-slate-600 md:flex">
        <a href="https://www.cleanpng.com/free/wedding.html" class="hover:text-slate-900">Wedding</a>
        <a href="https://www.cleanpng.com/free/Summer.html" class="hover:text-slate-900">Summer</a>
        <a href="https://www.cleanpng.com/free/Birthday.html" class="hover:text-slate-900">Birthday</a>
        <a href="https://www.cleanpng.com/free/Frame.html" class="hover:text-slate-900">Frame</a>
      </nav>
    </div>
    <div class="hidden items-center gap-4 md:flex">
      <label class="relative block">
        <span class="sr-only">Search PNG</span>
        <input id="header-search-input" type="text" placeholder="Search Summer PNG..." class="w-72 rounded-lg border border-slate-200 px-4 py-2 pr-11 text-sm" />
        <button id="header-search-btn" type="button" class="absolute right-3 top-1/2 inline-flex h-8 w-8 -translate-y-1/2 items-center justify-center rounded-md text-slate-500 transition hover:bg-slate-100 hover:text-slate-800" aria-label="Search">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><circle cx="11" cy="11" r="7"></circle><path d="M20 20l-3.5-3.5"></path></svg>
        </button>
      </label>
      <a href="https://members.cleanpng.com/login.html" class="text-sm font-semibold text-slate-700">Log in</a>
      <a href="https://members.cleanpng.com/register.html" class="rounded-lg bg-brand-green px-4 py-2 text-sm font-bold text-white">Sign up</a>
    </div>
  </div>
  <div class="border-t border-slate-100 px-4 py-3 sm:px-6 md:hidden">
    <label class="relative block">
      <span class="sr-only">Search PNG</span>
      <input id="mobile-header-search-input" type="text" placeholder="Search Summer PNG..." class="h-10 w-full rounded-lg border border-slate-200 px-4 pr-11 text-sm" />
      <button id="mobile-header-search-btn" type="button" class="absolute right-3 top-1/2 inline-flex h-8 w-8 -translate-y-1/2 items-center justify-center rounded-md text-slate-500 transition hover:bg-slate-100 hover:text-slate-800" aria-label="Search">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><circle cx="11" cy="11" r="7"></circle><path d="M20 20l-3.5-3.5"></path></svg>
      </button>
    </label>
  </div>
</header>

<main>
  <!-- ===================== HERO (EDIT COPY / HOT TAGS) ===================== -->
  <section class="bg-gradient-to-b from-emerald-50 to-white">
    <div class="page-shell px-4 pb-10 pt-14 text-center sm:px-6 lg:px-8 lg:pt-20">
      <h1 class="text-4xl font-black leading-tight tracking-tight sm:text-5xl">Over 12.6M+<br><span class="bg-gradient-to-r from-brand-green to-brand-soft bg-clip-text text-transparent">High-quality PNG</span></h1>
      <p class="mx-auto mt-5 max-w-3xl text-base text-slate-600">The world's largest archive for transparent PNG images. 100% Free!</p>
      <div class="mx-auto mt-8 max-w-3xl">
        <div class="flex rounded-xl border border-slate-200 bg-white p-2 shadow-card">
          <input id="hero-search-input" type="text" placeholder="Search Summer PNG..." class="flex-1 border-0 px-3 py-2 text-sm outline-none" />
          <button id="hero-search-btn" class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-bold text-white">Search</button>
        </div>
      </div>
      <div class="mx-auto mt-5 flex max-w-4xl flex-wrap items-center justify-center gap-2">
        <a class="chip" href="https://www.cleanpng.com/png/flower/">flower</a>
        <a class="chip" href="https://www.cleanpng.com/free/heart.html">heart</a>
        <a class="chip" href="https://www.cleanpng.com/free/arrow.html">arrow</a>
        <a class="chip" href="https://www.cleanpng.com/free/tree.html">tree</a>
        <a class="chip" href="https://www.cleanpng.com/free/frame.html">frame</a>
        <a class="chip" href="https://www.cleanpng.com/free/star.html">star</a>
        <a class="chip" href="https://www.cleanpng.com/free/cloud.html">cloud</a>
        <a class="chip" href="https://www.cleanpng.com/free/coffee.html">coffee</a>
        <a class="chip" href="https://www.cleanpng.com/free/food.html">food</a>
      </div>
    </div>
