/* Production utility patch for index.html
   Replaces the old Tailwind Play CDN runtime output for classes used on this page. */
.bg-black { background-color: rgb(0 0 0); }
.bg-slate-50 { background-color: rgb(248 250 252); }
.bg-gradient-to-b { background-image: linear-gradient(to bottom, var(--tw-gradient-stops)); }
.from-emerald-50 {
  --tw-gradient-from: #ecfdf5 var(--tw-gradient-from-position);
  --tw-gradient-to: rgb(236 253 245 / 0) var(--tw-gradient-to-position);
  --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to);
}
.to-brand-soft { --tw-gradient-to: #2dcf84 var(--tw-gradient-to-position); }
.to-white { --tw-gradient-to: #fff var(--tw-gradient-to-position); }
.border-0 { border-width: 0px; }
.border-white\/10 { border-color: rgb(255 255 255 / 0.1); }
.h-52 { height: 13rem; }
.w-72 { width: 18rem; }
.max-w-3xl { max-width: 48rem; }
.max-w-4xl { max-width: 56rem; }
.mb-6 { margin-bottom: 1.5rem; }
.p-2 { padding: 0.5rem; }
.px-3 { padding-left: 0.75rem; padding-right: 0.75rem; }
