# VERDEXIS - Frontend environment variables
# Copy to `.env.local` and fill in your free API keys.
# All Vite client-side env vars MUST be prefixed with VITE_.

# Alpha Vantage — https://www.alphavantage.co/support/#api-key  (25 calls/day free)
VITE_ALPHA_VANTAGE_KEY=

# Finnhub — https://finnhub.io/register  (60 calls/min free)
VITE_FINNHUB_KEY=

# CoinGecko public endpoints work without a key; leave blank unless using the Pro plan.
# VITE_COINGECKO_KEY=
