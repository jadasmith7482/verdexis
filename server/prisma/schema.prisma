generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  avatar       String?  // data URL or remote URL
  prefs        String?  // JSON blob: { currency, theme, notifications, ... }
  twoFactor    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  holdings      Holding[]
  walletBalances WalletBalance[]
  transactions  Transaction[]
  trades        Trade[]
  resetTokens   PasswordReset[]
  watchlist     Watchlist[]
  alerts        PriceAlert[]
  notifications Notification[]
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Holding {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  name      String
  amount    Float
  avgPrice  Float
  type      String  // 'crypto' | 'stock' | 'etf'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, symbol])
  @@index([userId])
}

model WalletBalance {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency  String   // 'USD' | 'BTC' | 'ETH' | 'SOL' ...
  symbol    String
  balance   Float    @default(0)
  available Float    @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, currency])
  @@index([userId])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind        String   // 'deposit' | 'withdraw' | 'transfer'
  currency    String
  amount      Float
  status      String   @default("completed")
  reference   String?  // address / counterparty
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}

model Trade {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  side      String   // 'buy' | 'sell'
  amount    Float
  price     Float
  total     Float
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  name      String
  type      String   @default("crypto") // 'crypto' | 'stock' | 'etf'
  createdAt DateTime @default(now())

  @@unique([userId, symbol])
  @@index([userId])
}

model PriceAlert {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol     String
  name       String
  direction  String   // 'above' | 'below'
  target     Float
  active     Boolean  @default(true)
  triggered  Boolean  @default(false)
  triggeredAt DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, active])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String   // 'alert' | 'trade' | 'deposit' | 'system'
  title     String
  body      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
