generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  avatar       String?  // data URL or remote URL
  prefs        String?  // JSON blob: { currency, theme, notifications, ... }
  twoFactor    Boolean  @default(false)
  role         String   @default("user")  // 'user' | 'admin'
  suspended    Boolean  @default(false)
  suspendedReason String?
  // Soft "hold" \u2014 less drastic than suspended. Login still works but
  // money-movement endpoints (withdraw / transfer) are blocked when active.
  // holdType controls scope: 'all' (block everything monetary), 'withdraw'
  // (block only withdraws), or 'transfer' (block only transfers).
  holdActive   Boolean  @default(false)
  holdType     String?  // 'all' | 'withdraw' | 'transfer'
  holdReason   String?  // canonical short code (see admin reasons list)
  holdNote     String?  // optional free-form note from the admin who placed it
  holdAt       DateTime?
  // KYC review queue
  kycStatus    String   @default("none")  // 'none' | 'pending' | 'approved' | 'rejected'
  kycNotes     String?
  kycReviewedAt DateTime?
  kycReviewedBy String?
  // Per-user money-movement caps (USD-equivalent). 0 / null = unlimited.
  dailyWithdrawLimit  Float?
  monthlyWithdrawLimit Float?
  dailyTransferLimit  Float?
  monthlyTransferLimit Float?
  // Comma-separated CIDR / IP list. Empty / null = no allowlist enforced.
  ipAllowlist  String?
  tokenVersion Int      @default(0)        // bump to invalidate outstanding JWTs
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  holdings      Holding[]
  walletBalances WalletBalance[]
  transactions  Transaction[]
  trades        Trade[]
  resetTokens   PasswordReset[]
  watchlist     Watchlist[]
  alerts        PriceAlert[]
  notifications Notification[]
  adminAudits   AdminAudit[]   @relation("AdminActor")
  audited       AdminAudit[]   @relation("AdminTarget")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Holding {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  name      String
  amount    Float
  avgPrice  Float
  type      String  // 'crypto' | 'stock' | 'etf'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, symbol])
  @@index([userId])
}

model WalletBalance {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency  String   // 'USD' | 'BTC' | 'ETH' | 'SOL' ...
  symbol    String
  balance   Float    @default(0)
  available Float    @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, currency])
  @@index([userId])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind        String   // 'deposit' | 'withdraw' | 'transfer' | 'fee' | 'reversal'
  currency    String
  amount      Float
  status      String   @default("completed")
  reference   String?  // address / counterparty
  // Optional pointer back to a transaction this one reverses (for /reverse).
  reversedFromId String?
  // Optional sub-classification (e.g. fee type: 'wire' | 'inactivity' | 'custody').
  subType     String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([reversedFromId])
}

model Trade {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  side      String   // 'buy' | 'sell'
  amount    Float
  price     Float
  total     Float
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  name      String
  type      String   @default("crypto") // 'crypto' | 'stock' | 'etf'
  createdAt DateTime @default(now())

  @@unique([userId, symbol])
  @@index([userId])
}

model PriceAlert {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol     String
  name       String
  direction  String   // 'above' | 'below'
  target     Float
  active     Boolean  @default(true)
  triggered  Boolean  @default(false)
  triggeredAt DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, active])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String   // 'alert' | 'trade' | 'deposit' | 'system'
  title     String
  body      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model AdminAudit {
  id           String   @id @default(cuid())
  actorId      String
  actor        User     @relation("AdminActor", fields: [actorId], references: [id], onDelete: Cascade)
  targetUserId String?
  target       User?    @relation("AdminTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  action       String   // 'user.update', 'wallet.set', 'transaction.create', ...
  payload      String?  // JSON snapshot of what changed
  createdAt    DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([targetUserId, createdAt])
}
