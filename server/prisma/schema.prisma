// Normalized schema: cleaned up invalid truncated line that caused P1012
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String?  @unique  // optional handle for sign-in (alternative to email)
  // Human-friendly investment account identifier, e.g. "VDX-9F4A2B1C".
  // Generated automatically on user creation; surfaced in admin UI and to the user.
  investmentId String?  @unique
  name         String
  passwordHash String
  avatar       String?  // data URL or remote URL
  prefs        String?  // JSON blob: { currency, theme, notifications, ... }
  twoFactor    Boolean  @default(false)
  role         String   @default("user")  // 'user' | 'admin'
  suspended    Boolean  @default(false)
  suspendedReason String?
  // Soft "hold" — less drastic than suspended. Login still works but
  // money-movement endpoints (withdraw / transfer) are blocked when active.
  // holdType controls scope: 'all' (block everything monetary), 'withdraw'
  // (block only withdraws), or 'transfer' (block only transfers).
  holdActive   Boolean  @default(false)
  holdType     String?  // 'all' | 'withdraw' | 'transfer'
  holdReason   String?  // canonical short code (see admin reasons list)
  holdNote     String?  // optional free-form note from the admin who placed it
  holdAt       DateTime?
  // KYC review queue
  kycStatus    String   @default("none")  // 'none' | 'pending' | 'approved' | 'rejected'
  kycNotes     String?
  kycReviewedAt DateTime?
  kycReviewedBy String?
  // Email verification — required before withdrawals are unlocked. New users
  // start unverified and receive a token via /api/auth/send-verification.
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  // Per-user money-movement caps (USD-equivalent). 0 / null = unlimited.
  dailyWithdrawLimit  Float?
  monthlyWithdrawLimit Float?
  dailyTransferLimit  Float?
  monthlyTransferLimit Float?
  // Comma-separated CIDR / IP list. Empty / null = no allowlist enforced.
  ipAllowlist  String?
  // Linked self-custody wallet (EIP-1193 / WalletConnect). Persisted so the
  // user sees their address everywhere they're signed in, and so deposit
  // attribution doesn't depend on a single browser's localStorage.
  walletAddress  String?
  walletChainId  String?  // EIP-155 hex, e.g. "0x1"
  walletProvider String?  // human label, e.g. "MetaMask", "WalletConnect"
  walletLinkedAt DateTime?
  tokenVersion Int      @default(0)        // bump to invalidate outstanding JWTs
  // Referral program fields
  referralCode String?  @unique            // unique code for this user to share (e.g., "VERDX-AB12")
  referrerId   String?                     // id of the user who referred this user
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  emailVerifications EmailVerification[]

  holdings      Holding[]
  walletBalances WalletBalance[]
  transactions  Transaction[]
  trades        Trade[]
  resetTokens   PasswordReset[]
  watchlist     Watchlist[]
  alerts        PriceAlert[]
  notifications Notification[]
  pendingDeposits PendingDeposit[]
  walletLinks   WalletLink[]
  reviews       Review[]
  adminAudits   AdminAudit[]   @relation("AdminActor")
  audited       AdminAudit[]   @relation("AdminTarget")
  referrals     Referral[]     @relation("Referrer")        // people this user referred
  referralBonuses ReferralBonus[] // bonuses earned from referrals
  dcaSchedules  DcaSchedule[]
}

// Self-custody wallets a user has linked. A user can attach multiple
// addresses (e.g. one MetaMask + one Trust mobile + one hardware wallet)
// and pick which one is the "primary" \u2014 that one is mirrored back into
// the legacy User.walletAddress / walletChainId / walletProvider fields
// for backward compat with everywhere that still reads from there
// (deposit attribution, admin user detail page, etc.).
model WalletLink {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Lower-cased EVM address (0x...).
  address     String
  // EIP-155 hex chain id, e.g. "0x1". Optional because some users may link
  // a wallet without specifying a chain (we read chainId at send-tx time).
  chainId     String?
  // Human label of the wallet provider, e.g. "MetaMask", "WalletConnect".
  provider    String?
  // Optional user-set nickname shown in the picker, e.g. "Cold storage".
  label       String?
  // Exactly one link per user is the active / mirrored one.
  isPrimary   Boolean  @default(false)
  linkedAt    DateTime @default(now())

  @@unique([userId, address])
  @@index([userId, isPrimary])
}

// On-chain deposit attempt the user kicked off from their linked wallet.
// The frontend captures the tx hash + chain immediately on submit; the
// admin (or future chain-watcher job) verifies the tx on a block explorer
// and credits the user's WalletBalance once it has enough confirmations.
model PendingDeposit {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  txHash      String   @unique
  chainId     String
  toAddress   String
  fromAddress String
  asset       String
  amount      Float
  status      String   @default("pending")
  note        String?
  creditedTxId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Holding {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  name      String
  amount    Float
  avgPrice  Float
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, symbol])
  @@index([userId])
}

model WalletBalance {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency  String
  symbol    String
  balance   Float    @default(0)
  available Float    @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, currency])
  @@index([userId])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind        String
  currency    String
  amount      Float
  status      String   @default("completed")
  reference   String?
  reversedFromId String?
  subType     String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([reversedFromId])
}

model Trade {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  side      String
  amount    Float
  price     Float
  total     Float
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  name      String
  type      String   @default("crypto")
  createdAt DateTime @default(now())

  @@unique([userId, symbol])
  @@index([userId])
}

model PriceAlert {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol     String
  name       String
  direction  String
  target     Float
  active     Boolean  @default(true)
  triggered  Boolean  @default(false)
  triggeredAt DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, active])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String
  title     String
  body      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model AdminAudit {
  id           String   @id @default(cuid())
  actorId      String
  actor        User     @relation("AdminActor", fields: [actorId], references: [id], onDelete: Cascade)
  targetUserId String?
  target       User?    @relation("AdminTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  action       String
  payload      String?
  createdAt    DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([targetUserId, createdAt])
}

// Generic key/value store for admin-managed app settings.
// Currently used for the deposit instructions blob (wire / crypto / web3
// destination addresses) so they're shared across devices and persist
// instead of living only in one admin's localStorage.
model AppSetting {
  key       String   @id
  value     String
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// Public testimonial / review left by a real user. Surfaced on the
// marketing homepage. One row per user (upserted on POST) so the same
// person can update their review without spawning duplicates. We pin
// the user's name + avatar at write-time so renaming/avatar changes
// don't retroactively rewrite the homepage testimonial unless the
// user explicitly re-submits.
model Review {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  text      String
  authorName   String
  authorAvatar String?
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([approved, createdAt])
}

// Referral tracking: links a referrer to a referee. Created when the referred user
// signs up using the referrer's code. Bonus creation is separate (ReferralBonus model)
// and is triggered only after the referee makes their first deposit.
model Referral {
  id        String   @id @default(cuid())
  referrerId String
  referrer   User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  refereeId  String
  refereeEmail String
  status    String   @default("pending")
  firstDepositAt DateTime?
  firstDepositAmount Float?
  referrerBonusUsd Float?
  refereeBonusUsd  Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([referrerId, createdAt])
  @@index([refereeEmail])
  @@index([status])
}

// Referral bonus tracking: stores info about bonuses awarded from referrals.
// Created when both a Referral becomes 'active' (referee deposits) AND the bonus
// is actually awarded (credited to user account or pending for later payout).
model ReferralBonus {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount       Float
  bonusType    String
  paymentMethod String  @default("trading_credit")
  status       String   @default("pending")
  creditedAt   DateTime?
  creditedTransactionId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status])
}


// Recurring dollar-cost-average buy schedule. The dca-poller (server-side
// cron) wakes every minute and fires any active schedule whose nextRunAt
// has passed — debits USD wallet, upserts the holding with weighted-avg
// cost basis, writes a Trade row, and updates lastRunAt + nextRunAt.
model DcaSchedule {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset         String   // symbol e.g. BTC
  assetId       String   // CoinGecko id e.g. bitcoin
  name          String
  amountUsd     Float
  intervalDays  Int
  active        Boolean  @default(true)
  // Cumulative bookkeeping so the UI can show invested / acquired / runs
  // without recomputing from Trade history every render.
  totalInvested Float    @default(0)
  totalAcquired Float    @default(0)
  runs          Int      @default(0)
  lastRunAt     DateTime?
  // Authoritative next-fire time. Set on create, updated after each run.
  nextRunAt     DateTime
  // Set when a tick is skipped (e.g. insufficient USD). Cleared on success.
  lastSkipReason String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([active, nextRunAt])
}

