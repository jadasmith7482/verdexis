# Server
PORT=4000
NODE_ENV=development
DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-to-a-32-byte-random-string"
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
# Optional: only set to enable email-based password reset preview
APP_BASE_URL=http://localhost:5173

# Optional: enable the LLM proxy at POST /api/ai/chat. When unset, the route
# returns 503 and the frontend falls back to its built-in rule-based answers.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Optional: forward orders submitted to POST /api/trades to Alpaca's paper
# trading API. When unset, trades execute against the local SQLite books only.
# ALPACA_KEY=
# ALPACA_SECRET=
# ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Optional market data providers. Server-side keys are NOT exposed to the
# browser — the API proxies the requests so the keys stay private.
# ALPHA_VANTAGE_KEY=        # 25 req/day free  — historical stock prices
# FINNHUB_API_KEY=          # 60 req/min free  — news + stock quotes
# TWELVE_DATA_API_KEY=      # 800 req/day free — fallback stock data
# NEWS_API_KEY=             # 100 req/day free — newsapi.org aggregator
# COINGECKO_API_KEY=        # demo key recommended on cloud hosts
# COINGECKO_API_TIER=demo   # demo | pro
